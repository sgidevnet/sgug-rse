diff -Naur netsurf-all-3.9.original/netsurf/content/fetchers/curl.c netsurf-all-3.9/netsurf/content/fetchers/curl.c
--- netsurf-all-3.9.original/netsurf/content/fetchers/curl.c	2019-07-17 09:37:00.000000000 +0000
+++ netsurf-all-3.9/netsurf/content/fetchers/curl.c	2021-05-08 17:33:49.019919360 +0000
@@ -894,6 +894,7 @@
  */
 static bool fetch_curl_process_headers(struct curl_fetch_info *f)
 {
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
 	long http_code;
 	CURLcode code;
 	fetch_msg msg;
@@ -942,6 +943,8 @@
 		return true;
 	}
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	if (f->abort)
 		return true;
 
@@ -1094,6 +1097,7 @@
 		 * object will be truncated in this case and leave it to
 		 * the content handlers to cope.
 		 */
+		NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
 		if (f->stopped ||
 		    (!f->had_headers &&	fetch_curl_process_headers(f))) {
 			; /* redirect with no body or similar */
@@ -1105,6 +1109,7 @@
 		 * response is smaller than that specified in the
 		 * Content-Length header.
 		 */
+		NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
 		if (!f->had_headers && fetch_curl_process_headers(f))
 			; /* redirect with partial body, or similar */
 		else {
@@ -1346,10 +1351,11 @@
 		inside_curl = false;
 		return size * nmemb;
 	}
-
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
 	if (f->abort || (!f->had_headers && fetch_curl_process_headers(f))) {
 		f->stopped = true;
 		inside_curl = false;
+		NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
 		return 0;
 	}
 
diff -Naur netsurf-all-3.9.original/netsurf/content/fs_backing_store.c netsurf-all-3.9/netsurf/content/fs_backing_store.c
--- netsurf-all-3.9.original/netsurf/content/fs_backing_store.c	2019-07-17 09:37:00.000000000 +0000
+++ netsurf-all-3.9/netsurf/content/fs_backing_store.c	2021-05-08 12:46:01.655905600 +0000
@@ -1692,7 +1692,7 @@
 		    offst);
 	if (wr != (ssize_t)bse->elem[elem_idx].size) {
 		NSLOG(netsurf, INFO,
-		      "Write failed %"PRIssizet" of %d bytes from %p at 0x%jx block %d errno %d",
+		      "Write failed %"PRIssizet" of %d bytes from %p at 0x%x block %d errno %d",
 		      wr,
 		      bse->elem[elem_idx].size,
 		      bse->elem[elem_idx].data,
@@ -1703,10 +1703,12 @@
 	}
 
 	NSLOG(netsurf, INFO,
-	      "Wrote %"PRIssizet" bytes from %p at 0x%jx block %d", wr,
+	      "Wrote %"PRIssizet" bytes from %p at 0x%x block %d", wr,
 	      bse->elem[elem_idx].data, (uintmax_t)offst,
 	      bse->elem[elem_idx].block);
 
+	NSLOG(netsurf, INFO, "ZZZDBG HI MOM!");
+
 	return NSERROR_OK;
 }
 
@@ -1772,6 +1774,8 @@
       uint8_t *data,
       const size_t datalen)
 {
+
+	NSLOG(netsurf, INFO, "ZZZDBG Now we're in that weird store function");
 	nserror ret;
 	struct store_entry *bse;
 	int elem_idx;
@@ -1798,6 +1802,7 @@
 	if (bse->elem[elem_idx].block != 0) {
 		/* small block storage */
 		ret = store_write_block(storestate, bse, elem_idx);
+		NSLOG(netsurf, INFO, "ZZZDBG Stored Write Block fc_backing_store 1800, ret %d", ret);
 	} else {
 		/* separate file in backing store */
 		ret = store_write_file(storestate, bse, elem_idx);
@@ -1862,7 +1867,7 @@
 		   offst);
 	if (rd != (ssize_t)bse->elem[elem_idx].size) {
 		NSLOG(netsurf, INFO,
-		      "Failed reading %"PRIssizet" of %d bytes into %p from 0x%jx block %d errno %d",
+		      "Failed reading %"PRIssizet" of %d bytes into %p from 0x%x block %d errno %d",
 		      rd,
 		      bse->elem[elem_idx].size,
 		      bse->elem[elem_idx].data,
@@ -1873,7 +1878,7 @@
 	}
 
 	NSLOG(netsurf, INFO,
-	      "Read %"PRIssizet" bytes into %p from 0x%jx block %d", rd,
+	      "Read %"PRIssizet" bytes into %p from 0x%x block %d", rd,
 	      bse->elem[elem_idx].data, (uintmax_t)offst,
 	      bse->elem[elem_idx].block);
 
@@ -2029,6 +2034,7 @@
  */
 static nserror release(nsurl *url, enum backing_store_flags bsflags)
 {
+	NSLOG(netsurf, INFO, "releasing memory object");
 	nserror ret;
 	struct store_entry *bse;
 	struct store_entry_element *elem;
diff -Naur netsurf-all-3.9.original/netsurf/content/llcache.c netsurf-all-3.9/netsurf/content/llcache.c
--- netsurf-all-3.9.original/netsurf/content/llcache.c	2019-07-17 09:37:00.000000000 +0000
+++ netsurf-all-3.9/netsurf/content/llcache.c	2021-05-08 15:51:58.159481920 +0000
@@ -53,6 +53,7 @@
 #include "content/backing_store.h"
 #include "content/urldb.h"
 
+
 /**
  * State of a low-level cache object fetch.
  */
@@ -1239,6 +1240,8 @@
 	unsigned int hloop;
 	int use;
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	allocsize = 10 + 1; /* object length */
 
 	allocsize += 10 + 1; /* request time */
@@ -1251,6 +1254,8 @@
 
 	allocsize += nsurl_length(object->url) + 1;
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	for (hloop = 0 ; hloop < object->num_headers ; hloop++) {
 		allocsize += strlen(object->headers[hloop].name) + 1;
 		allocsize += strlen(object->headers[hloop].value) + 1;
@@ -1264,6 +1269,8 @@
 	op = (char *)data;
 	datasize = allocsize;
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	/* the url, used for checking for collisions */
 	use = snprintf(op, datasize, "%s", nsurl_access(object->url));
 	if (use < 0) {
@@ -1276,6 +1283,8 @@
 	op += use;
 	datasize -= use;
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	/* object size */
 	use = snprintf(op, datasize, "%" PRIsizet, object->source_len);
 	if (use < 0) {
@@ -1287,6 +1296,8 @@
 	op += use;
 	datasize -= use;
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	/* Time of request */
 	use = nsc_sntimet(op, datasize, &object->cache.req_time);
 	if (use == 0)
@@ -1295,6 +1306,8 @@
 	op += use;
 	datasize -= use;
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	/* Time of response */
 	use = nsc_sntimet(op, datasize, &object->cache.res_time);
 	if (use == 0)
@@ -1303,6 +1316,8 @@
 	op += use;
 	datasize -= use;
 
+	NSLOG(netsurf, INFO, "ZZZDBG %s %s %d", __FILE__, __FUNCTION__, __LINE__);
+
 	/* Time of completion */
 	use = nsc_sntimet(op, datasize, &object->cache.fin_time);
