diff -Naur netsurf-all-3.9.original/libdom/bindings/xml/Makefile netsurf-all-3.9/libdom/bindings/xml/Makefile
--- netsurf-all-3.9.original/libdom/bindings/xml/Makefile	2019-07-17 09:36:59.000000000 +0000
+++ netsurf-all-3.9/libdom/bindings/xml/Makefile	2021-05-01 14:06:09.607208640 +0000
@@ -12,7 +12,7 @@
 
   # LibXML 2.6.26 has a bug in its headers that expects _POSIX_C_SOURCE to be 
   # defined. Define it here, even though we don't need it.
-  CFLAGS := $(CFLAGS) -D_POSIX_C_SOURCE
+  CFLAGS := $(CFLAGS)
 
   DO_XML_INSTALL := yes
 endif
