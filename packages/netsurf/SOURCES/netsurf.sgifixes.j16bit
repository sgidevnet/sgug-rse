diff -Naur netsurf-all-3.9.original/buildsystem/makefiles/Makefile.clang netsurf-all-3.9/buildsystem/makefiles/Makefile.clang
--- netsurf-all-3.9.original/buildsystem/makefiles/Makefile.clang	2019-07-17 09:36:59.000000000 +0000
+++ netsurf-all-3.9/buildsystem/makefiles/Makefile.clang	2021-05-01 14:06:09.552575840 +0000
@@ -3,8 +3,10 @@
 # as clang being mostly GCC-compatible on the command line
 
 CCDEF := -D
-CCOPT := -O2
-CCNOOPT := -O0
+#CCOPT := -O2
+#CCNOOPT := -O0
+CCOPT := -ONOPE
+CCNOOPT := -ONOPE
 CCDBG := -g
 CCINC := -I
 CCLIB := -L
@@ -12,8 +14,10 @@
 CCSHR := -fPIC
 
 CXXDEF := -D
-CXXOPT := -O2
-CXXNOOPT := -O0
+#CXXOPT := -O2
+#CXXNOOPT := -O0
+CXXOPT := -ONOPE
+CXXNOOPT := -ONOPE
 CXXDBG := -g
 CXXINC := -I
 CXXLIB := -L
diff -Naur netsurf-all-3.9.original/buildsystem/makefiles/Makefile.gcc netsurf-all-3.9/buildsystem/makefiles/Makefile.gcc
--- netsurf-all-3.9.original/buildsystem/makefiles/Makefile.gcc	2019-07-17 09:36:59.000000000 +0000
+++ netsurf-all-3.9/buildsystem/makefiles/Makefile.gcc	2021-05-01 14:06:09.561452720 +0000
@@ -2,8 +2,10 @@
 # We assume that we're using a standard GCC/binutils environment
 
 CCDEF := -D
-CCOPT := -O2
-CCNOOPT := -O0
+#CCOPT := -ONOPE
+#CCNOOPT := -ONOPE
+CCOPT :=
+CCNOOPT :=
 CCDBG := -g
 CCINC := -I
 CCLIB := -L
@@ -11,8 +13,10 @@
 CCSHR := -fPIC
 
 CXXDEF := -D
-CXXOPT := -O2
-CXXNOOPT := -O0
+#CXXOPT := -ONOPE
+#CXXNOOPT := -ONOPE
+CXXOPT :=
+CXXNOOPT :=
 CXXDBG := -g
 CXXINC := -I
 CXXLIB := -L
diff -Naur netsurf-all-3.9.original/buildsystem/makefiles/Makefile.norcroft netsurf-all-3.9/buildsystem/makefiles/Makefile.norcroft
